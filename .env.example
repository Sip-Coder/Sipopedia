VITE_APP_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SALES_EMAIL=
# Keep provider keys in Supabase Edge Function secrets, not in frontend env.
# Checkout Edge Function secrets:
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID_PRO=
# STRIPE_WEBHOOK_SECRET=
# APP_URL=
# ALLOWED_ORIGINS=
# Article-sharing Edge Function secrets:
# RESEND_API_KEY=
# ARTICLE_SHARE_FROM_EMAIL=

# Terminology pipeline controls (used by scripts/start-terms.js)
TERMS_TARGET=300
TERMS_SCORE_THRESHOLD=70
TERMS_NEAR_MISS_THRESHOLD=50
TERMS_DISCOVERY_MULTIPLIER=8
TERMS_FETCH_TIMEOUT_MS=12000
TERMS_AUTO_PUBLISH_APPROVED=true
TERMS_ROTATE_MODE=true
TERMS_LETTER_WINDOW=8
TERMS_SOURCES_PER_TYPE=2
TERMS_DISCOVERY_PASSES=3
TERMS_MIN_PROGRESS_PER_RUN=1
TERMS_RECOVER_UNPUBLISHED_PER_RUN=50

# Scoring weights
TERMS_WEIGHT_LEXICAL_BASE=20
TERMS_WEIGHT_STUDY_SIGNAL=20
TERMS_WEIGHT_DEFINITION_CUE=20
TERMS_WEIGHT_TECHNICAL_ROOT=15
TERMS_WEIGHT_SOURCE_AUTHORITY=10
TERMS_WEIGHT_SPECIFICITY=10
TERMS_WEIGHT_CONTEXT_QUALITY=5
