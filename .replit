modules = ["nodejs-22"]
[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
build = ["sh", "-c", "SIP_STUDIES_DEPLOYMENT_BUILD=1 npm run build:replit"]
deploymentTarget = "autoscale"
run = ["npm", "run", "start", "--", "--host", "0.0.0.0", "--port", "5000"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
